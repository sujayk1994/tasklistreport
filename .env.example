# ══════════════════════════════════════════════════════════════════════════════
#  Daily Task Manager — Environment Variables
#  Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_...

# Publishable key (safe to expose — baked into the frontend bundle at build time)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk proxy URL — allows Clerk auth to work on your custom domain.
# Set to:  https://YOUR_DOMAIN/api/__clerk
# For local Docker:  http://localhost:3000/api/__clerk
# Leave blank to auto-detect from browser URL (recommended for Render)
VITE_CLERK_PROXY_URL=

# ── Database ──────────────────────────────────────────────────────────────────
# For local Docker Compose this is set automatically.
# For Render this is injected from the managed database.
DATABASE_URL=postgresql://dailytasks:dailytasks_local@localhost:5432/dailytasks

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# The Gmail address that will SEND the daily report emails
GMAIL_USER=your@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one: myaccount.google.com → Security → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Application ───────────────────────────────────────────────────────────────
# Email address that gets the Admin panel inside the app
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# Random secret for session security (generate: openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-long-random-secret

# Server port (default: 3000)
PORT=3000
